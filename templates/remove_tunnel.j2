{# ======= IKEv2 / IPsec route-based VPN tunnel — REMOVAL (safe items only) ======= #}
{# BGP, CSR_LIST entries, and static routes are handled by the playbook tasks.    #}

{% set safe_desc = tunnel_desc | regex_replace('\\s+', '_') %}
{% set effective_acl_name = acl_name if (acl_name is defined and acl_name | length > 0) else safe_desc %}

{# ---- Tunnel interface (one shot removes interface + all sub-config) ---- #}
no interface Tunnel{{ tunnel_id }}

{# ---- Static route to remote peer ---- #}
no ip route {{ remote_peer_ip }} 255.255.255.255 10.138.1.1

{# ---- IP SLA + track ---- #}
no ip sla schedule {{ tunnel_id }}
no ip sla {{ tunnel_id }}
no track {{ tunnel_id }}

{# ---- Crypto stack ---- #}
no crypto ipsec profile IPSEC_PROF_T{{ tunnel_id }}
no crypto ikev2 profile PROF_T{{ tunnel_id }}
no crypto ikev2 keyring KEYRING_T{{ tunnel_id }}

{# ---- ACL (remove if acl_entries OR acl_name was provided) ---- #}
{% if (acl_entries is defined and acl_entries | length > 0)
      or (acl_name is defined and acl_name | length > 0) %}
no ip access-list extended {{ effective_acl_name }}
{% endif %}

{# ---- Inbound/Outbound prefix-lists & route-maps (DYNAMIC only) ---- #}
{% if routing_type | default('dynamic') == 'dynamic' %}
{% if inbound_pl_name is defined and inbound_pl_name | length > 0 %}
no ip prefix-list {{ inbound_pl_name }}
{% endif %}
{% if outbound_pl_name is defined and outbound_pl_name | length > 0 %}
no ip prefix-list {{ outbound_pl_name }}
{% endif %}
{% if inbound_rm_name is defined and inbound_rm_name | length > 0 %}
no route-map {{ inbound_rm_name }}
{% endif %}
{% if outbound_rm_name is defined and outbound_rm_name | length > 0 %}
no route-map {{ outbound_rm_name }}
{% endif %}
{% endif %}
