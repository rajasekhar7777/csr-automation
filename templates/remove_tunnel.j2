
{# ====================================================================
   IKEv2 / IPsec route-based VPN tunnel — REMOVAL (safe items only)

   BGP networks/neighbor, static routes, and CSR_LIST entries are
   handled by independent playbook tasks (for failure isolation).

   This template removes:
     - Tunnel interface
     - WAN host-route to remote peer
     - IP SLA + track
     - IPsec profile, IKEv2 profile, IKEv2 keyring
     - ACL (if eff_remove_acl=true)
     - Dynamic-mode inbound/outbound prefix-list & route-map

   Relies on playbook facts:
     eff_routing_type, eff_remove_acl, eff_remove_inbound_pl,
     eff_remove_outbound_pl, eff_remove_inbound_rm, eff_remove_outbound_rm,
     effective_keyring_name, effective_profile_name,
     effective_ipsec_profile_name, effective_acl_name, safe_desc
   And survey vars: tunnel_id, remote_peer_ip,
     inbound_pl_name, outbound_pl_name, inbound_rm_name, outbound_rm_name
   ==================================================================== #}

{# ---- Tunnel interface (one shot removes interface + all sub-config) ---- #}
no interface Tunnel{{ tunnel_id }}

{# ---- WAN host-route to remote peer ---- #}
no ip route {{ remote_peer_ip }} 255.255.255.255 10.138.1.1 name WAN_ROUTE_T{{ tunnel_id }}

{# ---- IP SLA + track ---- #}
no ip sla schedule {{ tunnel_id }}
no ip sla {{ tunnel_id }}
no track {{ tunnel_id }}

{# ---- Crypto stack (user-defined names) ---- #}
no crypto ipsec profile {{ effective_ipsec_profile_name }}
no crypto ikev2 profile {{ effective_profile_name }}
no crypto ikev2 keyring {{ effective_keyring_name }}

{# ---- ACL ---- #}
{% if eff_remove_acl | bool %}
no ip access-list extended {{ effective_acl_name }}
{% endif %}

{# ---- Inbound/Outbound prefix-lists & route-maps (DYNAMIC only) ---- #}
{% if eff_routing_type == 'dynamic' %}
{% if eff_remove_inbound_pl | bool and inbound_pl_name is defined and (inbound_pl_name | length) > 0 %}
no ip prefix-list {{ inbound_pl_name }}
{% endif %}
{% if eff_remove_outbound_pl | bool and outbound_pl_name is defined and (outbound_pl_name | length) > 0 %}
no ip prefix-list {{ outbound_pl_name }}
{% endif %}
{% if eff_remove_inbound_rm | bool and inbound_rm_name is defined and (inbound_rm_name | length) > 0 %}
no route-map {{ inbound_rm_name }}
{% endif %}
{% if eff_remove_outbound_rm | bool and outbound_rm_name is defined and (outbound_rm_name | length) > 0 %}
no route-map {{ outbound_rm_name }}
{% endif %}
{% endif %}
