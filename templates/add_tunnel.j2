{# ====================================================================
   IKEv2 / IPsec route-based VPN tunnel
   Hard-coded: IKEv2, IPsec route-based, wan=GigabitEthernet1, gw=10.138.1.1
   ==================================================================== #}

{% set _octet_bits = {'0':0,'128':1,'192':2,'224':3,'240':4,'248':5,'252':6,'254':7,'255':8} %}

{% set ln_entries = [] %}
{% if local_networks is defined and local_networks | length > 0 %}
{% for raw in local_networks.splitlines() %}
{% set line = raw | trim %}
{% if line | length > 0 %}
{% if '/' in line and (line.split() | length) == 1 %}
{% set net  = line.split('/')[0] %}
{% set bits = line.split('/')[1] | int %}
{% set full_octets = (bits // 8) %}
{% set rem         = (bits %  8) %}
{% set _table      = {0:'0',1:'128',2:'192',3:'224',4:'240',5:'248',6:'252',7:'254',8:'255'} %}
{% set parts = [] %}
{% for i in range(4) %}
{% if i < full_octets %}{% set _ = parts.append('255') %}
{% elif i == full_octets %}{% set _ = parts.append(_table[rem]) %}
{% else %}{% set _ = parts.append('0') %}{% endif %}
{% endfor %}
{% set _ = ln_entries.append({'net': net, 'mask': parts | join('.'), 'bits': bits}) %}
{% elif (line.split() | length) >= 2 %}
{% set p  = line.split() %}
{% set mo = p[1].split('.') %}
{% if (mo | length) == 4 %}
{% set bits = _octet_bits.get(mo[0],0) + _octet_bits.get(mo[1],0) + _octet_bits.get(mo[2],0) + _octet_bits.get(mo[3],0) %}
{% set _ = ln_entries.append({'net': p[0], 'mask': p[1], 'bits': bits}) %}
{% endif %}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}

crypto ikev2 proposal azure-proposal-VNG
 encryption aes-cbc-256 aes-cbc-128
 integrity sha1 sha256
 group 2 20 21 14 24

crypto ikev2 policy azure-policy-VNG
 proposal azure-proposal-VNG

crypto ikev2 keyring {{ effective_keyring_name }}
 peer {{ safe_desc }}
  address {{ remote_peer_ip }}
  pre-shared-key {{ vpn_psk }}

crypto ikev2 profile {{ effective_profile_name }}
{% if eff_match_identity_remote_type == 'address' %}
 match identity remote address {{ eff_match_identity_remote_value if (eff_match_identity_remote_value | length) > 0 else remote_peer_ip }} 255.255.255.255
{% else %}
 match identity remote fqdn {{ eff_match_identity_remote_value }}
{% endif %}
 authentication remote pre-share
 authentication local pre-share
 keyring local {{ effective_keyring_name }}
{% if (eff_identity_local_type | length) > 0 and (eff_identity_local_value | length) > 0 %}
{% if eff_identity_local_type == 'address' %}
 identity local address {{ eff_identity_local_value }}
{% else %}
 identity local fqdn {{ eff_identity_local_value }}
{% endif %}
{% endif %}
 lifetime {{ eff_ikev2_lifetime }}
 dpd 10 5 on-demand

crypto ipsec transform-set AES256-SHA256 esp-aes 256 esp-sha256-hmac
 mode tunnel

crypto ipsec profile {{ effective_ipsec_profile_name }}
 set transform-set AES256-SHA256
 set pfs group20
 set ikev2-profile {{ effective_profile_name }}

{% if acl_entries is defined and acl_entries | length > 0 %}
{% set acl_lines = acl_entries.splitlines() | map('trim') | reject('equalto','') | list %}
ip access-list extended {{ effective_acl_name }}
{% for line in acl_lines %}
 {{ line }}
{% endfor %}
{% endif %}

interface Tunnel{{ tunnel_id }}
 description {{ eff_tunnel_desc }}
 ip address {{ tunnel_local_ip }} 255.255.255.252
 tunnel source GigabitEthernet1
 tunnel mode ipsec ipv4
 tunnel destination {{ remote_peer_ip }}
 tunnel protection ipsec profile {{ effective_ipsec_profile_name }}
 ip tcp adjust-mss 1370
{% if acl_entries is defined and acl_entries | length > 0 %}
 ip access-group {{ effective_acl_name }} in
{% endif %}

ip sla {{ tunnel_id }}
 icmp-echo {{ effective_sla_target }} source-interface Tunnel{{ tunnel_id }}
 frequency 5
ip sla schedule {{ tunnel_id }} life forever start-time now
track {{ tunnel_id }} ip sla {{ tunnel_id }} reachability

ip route {{ remote_peer_ip }} 255.255.255.255 10.138.1.1 name WAN_ROUTE_T{{ tunnel_id }}

{% if routing_type == 'dynamic'
      and inbound_pl_name is defined and inbound_pl_name | length > 0
      and inbound_prefixes is defined and inbound_prefixes | length > 0 %}
{% for prefix in (inbound_prefixes.splitlines() | map('trim') | reject('equalto','') | list) %}
ip prefix-list {{ inbound_pl_name }} seq {{ loop.index * 5 }} permit {{ prefix }}
{% endfor %}
{% endif %}

{% if routing_type == 'dynamic'
      and outbound_pl_name is defined and outbound_pl_name | length > 0
      and outbound_prefixes is defined and outbound_prefixes | length > 0 %}
{% for prefix in (outbound_prefixes.splitlines() | map('trim') | reject('equalto','') | list) %}
ip prefix-list {{ outbound_pl_name }} seq {{ loop.index * 5 }} permit {{ prefix }}
{% endfor %}
{% endif %}

{% if routing_type == 'dynamic'
      and inbound_rm_name is defined and inbound_rm_name | length > 0
      and inbound_pl_name is defined and inbound_pl_name | length > 0 %}
route-map {{ inbound_rm_name }} permit 10
 match ip address prefix-list {{ inbound_pl_name }}
{% endif %}
{% if routing_type == 'dynamic'
      and outbound_rm_name is defined and outbound_rm_name | length > 0
      and outbound_pl_name is defined and outbound_pl_name | length > 0 %}
route-map {{ outbound_rm_name }} permit 10
 match ip address prefix-list {{ outbound_pl_name }}
{% endif %}

{% if ln_entries | length > 0 %}
{% for e in ln_entries %}
ip prefix-list {{ eff_csr_pl_name }} seq {{ (pl_next_seq | int) + (loop.index0 * 5) }} permit {{ e.net }}/{{ e.bits }}{% if csr_pl_lege is defined and (csr_pl_lege | trim | length) > 0 %} {{ csr_pl_lege | trim }}{% endif %}

{% endfor %}
{% endif %}

{% set want_bgp = (routing_type == 'dynamic') or (ln_entries | length > 0) %}
{% if want_bgp %}
router bgp {{ eff_local_asn }}
 bgp log-neighbor-changes
{% if routing_type == 'dynamic' %}
 neighbor {{ bgp_neighbor_ip }} remote-as {{ remote_asn }}
 neighbor {{ bgp_neighbor_ip }} description BGP_TO_{{ safe_desc }}
 neighbor {{ bgp_neighbor_ip }} update-source Tunnel{{ tunnel_id }}
 neighbor {{ bgp_neighbor_ip }} timers 10 30 30
 neighbor {{ bgp_neighbor_ip }} ebgp-multihop 10
{% if bgp_password is defined and bgp_password | length > 0 %}
 neighbor {{ bgp_neighbor_ip }} password {{ bgp_password }}
{% endif %}
{% endif %}
 address-family ipv4
{% for e in ln_entries %}
  network {{ e.net }} mask {{ e.mask }}
{% endfor %}
{% if routing_type == 'dynamic' %}
  neighbor {{ bgp_neighbor_ip }} activate
  neighbor {{ bgp_neighbor_ip }} soft-reconfiguration inbound
{% if inbound_rm_name is defined and inbound_rm_name | length > 0 %}
  neighbor {{ bgp_neighbor_ip }} route-map {{ inbound_rm_name }} in
{% endif %}
{% if outbound_rm_name is defined and outbound_rm_name | length > 0 %}
  neighbor {{ bgp_neighbor_ip }} route-map {{ outbound_rm_name }} out
{% endif %}
{% endif %}
 exit-address-family
{% endif %}

{% if routing_type == 'static' and ln_entries | length > 0 %}
{% for e in ln_entries %}
ip route {{ e.net }} {{ e.mask }} Tunnel{{ tunnel_id }} name {{ safe_desc }}_NET{{ loop.index }}
{% endfor %}
{% endif %}
