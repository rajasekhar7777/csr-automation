! ==========================================================
! 1. IKE LOGIC (Selects IKEv1 or IKEv2)
! ==========================================================
{% if ike_version == "2" %}
! --- IKEv2 Mode ---
crypto ikev2 keyring KEYRING_{{ tunnel_id }}
 peer PEER_{{ tunnel_id }}
  address {{ remote_peer_ip }}
  pre-shared-key {{ vpn_psk }}

crypto ikev2 profile PROFILE_{{ tunnel_id }}
 match identity remote address {{ remote_peer_ip }} 255.255.255.255
 authentication remote pre-share
 authentication local pre-share
 keyring local KEYRING_{{ tunnel_id }}
 lifetime 28800
 dpd 10 5 on-demand
{% else %}
! --- IKEv1 Mode ---
crypto isakmp key {{ vpn_psk }} address {{ remote_peer_ip }}
crypto isakmp profile PROF_{{ tunnel_id }}
   keyring VPN
   match identity address {{ remote_peer_ip }} 255.255.255.255
{% endif %}

! ==========================================================
! 2. CONNECTIVITY LOGIC (Selects Route-Based or Policy-Based)
! ==========================================================
{% if vpn_mode == "route_based" %}
! --- VTI / Route-Based VPN ---
crypto ipsec profile IPSEC_PROF_{{ tunnel_id }}
 set transform-set {{ transform_set | default('AES256-SHA256') }}
 set pfs {{ pfs_group | default('group20') }}
 {% if ike_version == "2" %}set ikev2-profile PROFILE_{{ tunnel_id }}{% else %}set isakmp-profile PROF_{{ tunnel_id }}{% endif %}

interface Tunnel{{ tunnel_id }}
 description **** {{ tunnel_desc }} ****
 ip address {{ tunnel_local_ip }} 255.255.255.252
 tunnel source GigabitEthernet1
 tunnel destination {{ remote_peer_ip }}
 tunnel mode ipsec ipv4
 tunnel protection ipsec profile IPSEC_PROF_{{ tunnel_id }}
 ip tcp adjust-mss 1370

{% else %}
! --- Crypto Map / Policy-Based VPN ---
ip access-list extended ACL_T{{ tunnel_id }}
 {{ policy_acl_line }}

crypto map MYMAP {{ tunnel_id }} ipsec-isakmp
 description **** {{ tunnel_desc }} ****
 set peer {{ remote_peer_ip }}
 set transform-set {{ transform_set | default('AES256-SHA256') }}
 {% if ike_version == "2" %}set ikev2-profile PROFILE_{{ tunnel_id }}{% else %}set isakmp-profile PROF_{{ tunnel_id }}{% endif %}
 match address ACL_T{{ tunnel_id }}
{% endif %}

! ==========================================================
! 3. ROUTING LOGIC (Prefix Lists, Route Maps, BGP)
! ==========================================================
{% if new_prefix_list != "" %}
ip prefix-list {{ new_prefix_list }} seq 5 permit {{ prefix_network }}
{% endif %}

{% if new_route_map != "" %}
route-map {{ new_route_map }} permit 10
 match ip address prefix-list {{ new_prefix_list }}
{% endif %}

{% if enable_bgp == "true" %}
router bgp 398957
 neighbor {{ bgp_neighbor_ip }} remote-as {{ remote_asn }}
 neighbor {{ bgp_neighbor_ip }} description BGP_TO_{{ tunnel_desc }}
 {% if vpn_mode == "route_based" %}neighbor {{ bgp_neighbor_ip }} update-source Tunnel{{ tunnel_id }}{% endif %}
 address-family ipv4
  neighbor {{ bgp_neighbor_ip }} activate
  {% if new_route_map != "" %}neighbor {{ bgp_neighbor_ip }} route-map {{ new_route_map }} out{% endif %}
 exit-address-family
{% endif %}
