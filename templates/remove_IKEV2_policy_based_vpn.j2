{# ====================================================================
   Policy-based IKEv2/IPsec VPN — Removal
   Removes: crypto map seq, ACL, IKEv2 profile, IKEv2 keyring
   (BGP networks, static routes, CSR_LIST seqs are handled as
    independent playbook tasks for safety.)
   ==================================================================== #}

{% set safe_desc              = crypto_map_desc | regex_replace('\\s+', '_') %}
{% set effective_acl_name     = acl_name        if (acl_name        | length) > 0 else safe_desc %}
{% set effective_keyring_name = keyring_name    if (keyring_name    | length) > 0 else ('KEYRING_' ~ safe_desc) %}
{% set effective_profile_name = profile_name    if (profile_name    | length) > 0 else ('PROF_'    ~ safe_desc) %}

no crypto map {{ crypto_map_name }} {{ crypto_map_id }}

{% if remove_acl | bool %}
no ip access-list extended {{ effective_acl_name }}
{% endif %}

{% if remove_profile | bool %}
no crypto ikev2 profile {{ effective_profile_name }}
{% endif %}

{% if remove_keyring | bool %}
no crypto ikev2 keyring {{ effective_keyring_name }}
{% endif %}
